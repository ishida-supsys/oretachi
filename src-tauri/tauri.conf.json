{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oretachi",
  "version": "0.19.6",
  "identifier": "com.ia.oretachi",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ishida-supsys/oretachi/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxQjBDQTZBOEUyNjBDRDEKUldUUkRDYU9hc3F3TVhwbFhFTlVEb0lJcVJENjlZMENuRVlRSjkvalIrakZLbW9qT1VpOGZ5cGoK"
    },
    "cli": {
      "args": [
        {
          "name": "notify",
          "short": "n",
          "description": "通知するワークツリー名",
          "takesValue": true
        }
      ]
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "oretachi",
        "width": 800,
        "height": 600,
        "visible": false,
        "dragDropEnabled": false,
        "transparent": true,
        "shadow": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "ishida-supsys",
    "shortDescription": "Multi-session terminal manager for developers",
    "longDescription": "oretachi is a desktop application for managing multiple terminal sessions with a tabbed interface, split-pane layout, worktree support, and tray notifications to keep your development workflow organized.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}